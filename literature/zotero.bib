@article{borisova_adaptation_2020,
	title = {Adaptation of the {TOSCA} standard model for the Kubernetes container environment},
	rights = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/{IEEE}.html},
	url = {https://ieeexplore.ieee.org/document/9356983/},
	doi = {10.1109/IVMEM51402.2020.00008},
	abstract = {The main difference between container-based and virtualization-based cloud environments is the way of the virtualization methods for {OS} and auxiliary resources. Software applications can be both deployed in a cloud on virtual machines or in local data centres on physical machines. Containers are based on {OS}-level virtualization. So, container applications can be deployed on a virtual machine in the cloud too. To deal with the growth of various, but functionally similar cloud environments, the {TOSCA} [1] (Topology and Orchestration for Cloud Applications) standard was created. It allows to describe deployment resources in a {TOSCA} Domain-specific language that does not depend on the provider. Kubernetes [8] is an open-source system for deployment automation, scaling, and management of containerized applications. {TOSCA} standard was created to describe cloud applications, but the model may be suitable for describing container applications that Kubernetes orchestrate. This paper considers Kubernetes as a cloud provider and examines the applicability of the {TOSCA} standard for unifying deployment and orchestration not only of resources provided by virtualization-based clouds but also of containerized ones.},
	pages = {9--14},
	journaltitle = {2020 Ivannikov Memorial Workshop ({IVMEM})},
	author = {Borisova, Alexandra and Shvetcova, Valeriya and Borisenko, Oleg},
	urldate = {2025-03-23},
	date = {2020-09},
	note = {Conference Name: 2020 Ivannikov Memorial Workshop ({IVMEM})
		{ISBN}: 9781728190884
		Place: Orel, Russia
		Publisher: {IEEE}},
}

@article{bellendorf_specification_2020,
	title = {Specification of cloud topologies and orchestration using {TOSCA}: a survey},
	volume = {102},
	issn = {1436-5057},
	url = {https://doi.org/10.1007/s00607-019-00750-3},
	doi = {10.1007/s00607-019-00750-3},
	shorttitle = {Specification of cloud topologies and orchestration using {TOSCA}},
	abstract = {Topology and Orchestration Specification for Cloud Applications ({TOSCA}) is an {OASIS} standard for specifying the topology of cloud applications, their deployment on physical or virtual cloud resources, and their orchestration. In recent years, the cloud research community has shown significant interest in {TOSCA}, leading to an increasing number of related publications. Such publications address a wide-ranging set of topics around {TOSCA}, e.g., devise sophisticated cloud orchestration methodologies using {TOSCA}, extend the language of {TOSCA}, or present tools for manipulating {TOSCA} models. To help researchers and practitioners overview this multifaceted area of research, this paper presents the results of a systematic survey of the relevant literature. We have processed over 120 papers and categorized them, leading to a taxonomy with 6 categories and 19 subcategories. The analysis of the results reveals several notable tendencies, as well as areas requiring future research.},
	pages = {1793--1815},
	number = {8},
	journaltitle = {Computing},
	shortjournal = {Computing},
	author = {Bellendorf, Julian and Mann, Zoltán Ádám},
	urldate = {2025-03-23},
	date = {2020-08-01},
	langid = {english},
	keywords = {68-02, 68M01, 68M11, 68U35, Artificial Intelligence, Cloud computing, Cloud orchestration, Cloud topology, {TOSCA}},
}

@inproceedings{agarwal_compliance-as-code_2022,
	title = {Compliance-as-Code for Cybersecurity Automation in Hybrid Cloud},
	url = {https://ieeexplore.ieee.org/document/9860731},
	doi = {10.1109/CLOUD55607.2022.00066},
	abstract = {Automation of cybersecurity processes has become crucial with large scale deployment of sensitive workloads in regulated on-prem, private, and public cloud environments. Regulatory and standards bodies such as Payment Card Industry ({PCI}), Federal Financial Institutions Examination Council ({FFIEC}), International Organization for Standardization ({ISO}), and others govern the minimal set of cybersecurity controls that an organization must implement. To meet such requirements while maintaining business agility, organizations need to modernize from manual document based compliance management to automated processes for continuous compliance. This modernized process is called compliance-as-code. In this paper, we present an architecture for compliance-as-code based on a standardized framework. We identify several design choices and our rationale behind those. Specifically, we introduce a system for manipulating compliance information in a standardized manner and a data interchange protocol for inter-operable communication of compliance information. We demonstrate the scalability of our approach and briefly describe deployment and experimental results in real world settings.},
	eventtitle = {2022 {IEEE} 15th International Conference on Cloud Computing ({CLOUD})},
	pages = {427--437},
	booktitle = {2022 {IEEE} 15th International Conference on Cloud Computing ({CLOUD})},
	author = {Agarwal, Vikas and Butler, Chris and Degenaro, Lou and Kumar, Arun and Sailer, Anca and Steinder, Gosia},
	urldate = {2025-03-23},
	date = {2022-07},
	note = {{ISSN}: 2159-6190},
	keywords = {Industries, Automation, Cloud computing security, cloud security, compliance-as-code, continuous compliance, {ISO}, {ISO} Standards, Protocols, Scalability, security and compliance},
}

