        <mxCell id="Lzv2f7MgehNdQIw8qka4-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Identifizieren regulatorischer Vorgaben (e.g. Klassifizierung)&lt;/div&gt;" vertex="1">
