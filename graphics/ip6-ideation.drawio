        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-86" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit digitale Personenidentitäen über&amp;nbsp; ihren Lifecycle hinweg in allen Cloud-Umgebungen zu verwalten&lt;/div&gt;" vertex="1">
