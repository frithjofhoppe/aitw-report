        </mxCell>
        <mxCell id="696EZM2kDOvMzFpwea1o-1" edge="1" parent="1" source="FToHH90Hd881fiy44MfF-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;endFill=0;" target="FToHH90Hd881fiy44MfF-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FToHH90Hd881fiy44MfF-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;b&gt;Problematik/Motivation:&lt;/b&gt;&lt;div&gt;Governance die vorgaben aus den Regulatorien auf die einzelnen Aspekte der Landing Zone zu mappen&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="160" x="2710" y="-1210.75" as="geometry" />
        </mxCell>
        <mxCell id="KMDuPJAnvAtTsuf9FIJh-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;br&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&lt;strong&gt;#&lt;/strong&gt;&lt;/th&gt;&lt;th&gt;&lt;strong&gt;Use Case&lt;/strong&gt;&lt;/th&gt;&lt;th&gt;&lt;strong&gt;Relevante Capabilities (aus deiner Map, reduziert!)&lt;/strong&gt;&lt;/th&gt;&lt;th&gt;&lt;strong&gt;Warum ist dieser Use Case für Unternehmen wichtig?&lt;/strong&gt;&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;1&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Provisionierung einer neuen Landing Zone (Standard/Secure/Regulated)&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;LZ Portfolio Mgmt, Provisioning Execution, Baseline Mgmt, Policy Mgmt, Compliance Execution, Network Architecture, IAM Governance&lt;/td&gt;&lt;td&gt;Hohe Priorität, da jede neue LZ eine &lt;em&gt;kritische Grundlage&lt;/em&gt; bildet. Fehler hier multiplizieren sich über Jahre und viele Workloads.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;2&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Onboarding einer neuen Applikation in eine bestehende LZ&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Operational Readiness, Tagging &amp;amp; Naming, Access Mgmt, Resource Config Governance, Connectivity Governance, Observability Governance&lt;/td&gt;&lt;td&gt;Unternehmen wollen neue Apps schnell &amp;amp; sicher bereitstellen. Ein klarer Onboarding-Prozess vermeidet Drift, Risiko &amp;amp; Verzögerung.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;3&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Durchsetzung von Security- &amp;amp; Compliance-Regeln über mehrere Clouds hinweg&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Policy Mgmt, Baseline Mgmt, Compliance Execution, Drift Detection, Evidence Governance&lt;/td&gt;&lt;td&gt;Kritisch für regulierte Branchen → FINMA, DORA, ISO. Ohne schnittstellenübergreifende Policies entsteht Chaos.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;4&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Sichere Verbindung zwischen Cloud &amp;amp; On-Prem&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Connectivity &amp;amp; Routing Governance, Network Security Governance, DNS &amp;amp; Naming Governance, Traffic Inspection&lt;/td&gt;&lt;td&gt;Multi-Cloud ist fast immer Hybrid. Falsche Connectivity ist &lt;em&gt;Risiko #1&lt;/em&gt; für Performance, Security &amp;amp; Kosten.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;5&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Zero-Trust-Absicherung von internem Ost/West-Traffic&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Network Security Governance, Traffic Inspection Governance, Resource Config Governance&lt;/td&gt;&lt;td&gt;Moderne Angriffe verlaufen &lt;strong&gt;lateral&lt;/strong&gt;. Zero-Trust intern ist essenziell, um Kompromittierung zu verhindern.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;6&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Identitätsföderation &amp;amp; kontrollierte Verwaltung privilegierter Zugänge&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Federation &amp;amp; Trust Governance, Privileged Access Governance, User Identity Mgmt, Access Review&lt;/td&gt;&lt;td&gt;Identität ist der neue Perimeter. Multi-Cloud verstärkt IAM-Komplexität erheblich. Ein kritischer Erfolgsfaktor.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;7&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Sicherstellung der Observability &amp;amp; Auditfähigkeit&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Observability Governance, Audit Trail Governance, Evidence Collection, Compliance Execution&lt;/td&gt;&lt;td&gt;Ohne Logs/Monitoring kannst du keine Incidents untersuchen, kein Audit bestehen, kein Operate betreiben.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;8&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Kostenkontrolle &amp;amp; Verantwortlichkeitsklarheit durch Tagging/FinOps&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Tagging &amp;amp; Naming Governance, Cost Governance, Policy Mgmt&lt;/td&gt;&lt;td&gt;Cloud-Kosten können &lt;em&gt;unkontrolliert explodieren&lt;/em&gt;. Tags sind das Fundament für Chargeback/Showback &amp;amp; Kostentransparenz.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;9&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Freigabe &amp;amp; Governance von SaaS-Integrationen &amp;amp; Drittanbieter-Services&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;SaaS Integration Governance, Third-Party Service Approval, Connectivity Governance, Security Governance&lt;/td&gt;&lt;td&gt;SaaS macht heute &amp;gt;50% der Cloud-Integration aus. Ohne Governance entstehen Data-Leaks, Shadow IT &amp;amp; Compliance-Probleme.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;10&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Standards &amp;amp; Wiederholbarkeit in Multi-Cloud durch Baseline- und Blueprint-Management&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Baseline Mgmt, Configuration Governance, Version &amp;amp; Change Mgmt, Policy Mgmt&lt;/td&gt;&lt;td&gt;Ohne Wiederholbarkeit entsteht jede Cloud-Umgebung als „Snowflake“. Hoher Aufwand, hohe Kosten, hohe Security-Risiken.&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="390" width="1380" x="2030" y="680" as="geometry" />
        </mxCell>
        <mxCell id="696EZM2kDOvMzFpwea1o-3" edge="1" parent="1" source="696EZM2kDOvMzFpwea1o-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;endFill=1;" target="FToHH90Hd881fiy44MfF-1">
