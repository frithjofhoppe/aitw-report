          <mxGeometry height="65" width="160" x="4817" y="-2809.75" as="geometry" />
        </mxCell>
        <mxCell id="XOaByyi2WHC7JeqZsVpU-22" parent="1" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;dashed=1;whiteSpace=wrap;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Policy and Compliance Lifecycle Governance&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="370" width="200" x="2796" y="-2924" as="geometry" />
        </mxCell>
        <mxCell id="XOaByyi2WHC7JeqZsVpU-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#49B9FF;" value="Policy lifecycle management" vertex="1">
