        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-89" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Rechtevergabe zu prüfen und sicherstellen, dass Identitäten nur die nötigen Rechte für die jeweiligen Aufgaben haben&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1060" y="668.5" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-90" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit besondere / priviligierte Rechtevergabe zu definieren, kontrollieren und auditierbar zu machen (Bspw. definieren von Admin-Rollen, JIT Zugriff etc.)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1060" y="750" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-91" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit zu bestimmen in welchen Systemen die Personenidentitäten, Anwendungsidentitäten etc akzeptiert werden (bspw mapping claims, anmelde flows etc.)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1060" y="834" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-92" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit&amp;nbsp; zu&amp;nbsp; definieren wie Baselines enforced, remidation gemacht werden, monitoring der compliance aussieht&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1735" y="419.5" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-93" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit zu erkennen ob Veränderungen an der Foundation vom SOLL-Zustand entstanden sind&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="2391" y="505" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-94" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Regelwerke zu identifizieren welche Anforderungen beinhalten die potentiell für LZ oder Foundations relevant sind&amp;nbsp; (bspw SI001, ISO etc.)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1735" y="508.5" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-95" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Mindesttstandards basierend auf Polices zu definierne welche in den LZ eingehalten werden müssen&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1734.5" y="592" as="geometry" />
        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-96" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Policies&amp;nbsp; aus Anforderungen abzuleiten und diese zu definieren (bspw operativ mapping auf existieren vendor spezfische Policies)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="1735" y="685" as="geometry" />
        </mxCell>
        <mxCell id="pxIF99jQIkRb-W20V7F3-1" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit den Lifecylce einer Policy zu definieren (prozesse für entstehung, reviewen, updates, entfernung etc. definien -&amp;gt; EA levlel. Policy Management ist operativl)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="2390.75" y="416" as="geometry" />
        </mxCell>
        <mxCell id="pxIF99jQIkRb-W20V7F3-2" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit konsistent und durchsetzbare Regeln für die Benennung und das Tagging von Ressourcen zu definieren&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="2391" y="595" as="geometry" />
        </mxCell>
        <mxCell id="pxIF99jQIkRb-W20V7F3-3" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit technische Standards zu definieren wie einzelne Ressourcen konkret konfiguriert sein müsse (bspw welcher Parameter bei resourcen sind wie zu wählen, damit sie einem standard entsprechen -&amp;gt; nur standard nicht enforcen)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="2391" y="681" as="geometry" />
        </mxCell>
        <mxCell id="4Z1l0a7JNxmqqxo_deVm-1" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit einheitliche Architekturprinzipien und Standards zu definieren welche LZ übergreifend anwendbar sind (bspw hub-and-spoke, mesh etc)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="3024" y="423" as="geometry" />
        </mxCell>
        <mxCell id="4Z1l0a7JNxmqqxo_deVm-2" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Regeln/Richtlinien zur Absicherung des Netzwerkverkehrs über alle LZ und Cloud-Plattformen definieren zu können (bspw Isolation zwischen LZ, Zero trust prinzipien etc.)&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="3024" y="512" as="geometry" />
        </mxCell>
        <mxCell id="4Z1l0a7JNxmqqxo_deVm-3" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Routes, Traffic etc zwischen Cloud-Plattformen&amp;nbsp; und LZ zu standardisieren und deren Einhaltung sicherzustellen&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="3025.25" y="602" as="geometry" />
        </mxCell>
        <mxCell id="4Z1l0a7JNxmqqxo_deVm-4" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Standards für Domain-Namen, Namensräume, DNS Zonen etc zu definieren und die Einhaltung zu gewährleisten&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="3025" y="690" as="geometry" />
        </mxCell>
        <mxCell id="4Z1l0a7JNxmqqxo_deVm-5" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit&amp;nbsp; Regeln und Standards zu definieren wie der Netzwerkverkehr überwacht und analysiert werden soll&lt;/div&gt;" vertex="1">
          <mxGeometry height="79" width="140" x="3025" y="777" as="geometry" />
        </mxCell>
