        </mxCell>
        <mxCell id="ExnGLDjjqaEZx0Gqr_KJ-88" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=7;fontColor=default;fillColor=#FFFFFF;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;Fähigkeit Zugriff von Identitäten, Rollen, Gruppen auf Ressourcen zu zu vergeben, entziehen. Rollen definieren etc. (-&amp;gt; operativ)&lt;/div&gt;" vertex="1">
